# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Required: Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required: Tavily → https://app.tavily.com
TAVILY_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:    sqlite:///./armoriq.db
# Production:   postgresql://user:pass@host/dbname?sslmode=require  (Neon)
DATABASE_URL=sqlite:///./armoriq.db

# ─── Backend ──────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on (Railway injects PORT automatically)
PORT=8000

# Comma-separated allowed origins for CORS
# Local dev:    * (allow all)
# Production:   https://your-app.vercel.app
CORS_ORIGINS=*

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Production (set these in Vercel dashboard — use your Railway service URL):
# NEXT_PUBLIC_API_URL=https://<service>.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://<service>.up.railway.app/ws
